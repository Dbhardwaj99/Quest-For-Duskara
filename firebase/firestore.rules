rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function roomMember(roomID) {
      return signedIn() && request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomID)).data.memberIDs;
    }
    match /rooms/{roomID} {
      allow read: if roomMember(roomID);
      allow write: if false;
      match /members/{uid} { allow read: if roomMember(roomID); allow write: if false; }
      match /world/{doc} { allow read: if roomMember(roomID); allow write: if false; }
      match /state/{doc} { allow read: if roomMember(roomID); allow write: if false; }
      match /events/{doc} { allow read: if roomMember(roomID); allow write: if false; }
      match /processedActions/{doc} { allow read, write: if false; }
    }
    match /inviteCodes/{doc} { allow read, write: if false; }
    match /matchmakingTickets/{uid} { allow read: if signedIn() && request.auth.uid == uid; allow write: if false; }
    match /notificationTokens/{uid}/{token} { allow read, write: if false; }
    match /{document=**} { allow read, write: if false; }
  }
}
